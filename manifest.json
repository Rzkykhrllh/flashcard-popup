{
  "manifest_version": 3,
  "name": "Nihongo Popup — kanji yang ngeganggu",
  "version": "0.1.0",
  "description": "Flashcard bahasa Jepang dari Google Sheet kamu, muncul tiba-tiba sambil kamu kerja. Recall, lalu nilai sendiri: tau / lupa.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nihongo Popup",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "permissions": ["storage", "alarms", "scripting"],
  "host_permissions": ["https://docs.google.com/*", "<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
